---
import BaseLayout from "../../components/BaseLayout/BaseLayout.astro";
import GalleryIndex from "../../components/GalleryIndex.astro";
import galleryData from "../../data/gallery-es.json";

const translations = {
  galleryTitle: "Galería",
  galleryDescriptionLine1: "Colección de arte contemporáneo",
  galleryDescriptionLine2: "De una joven artista ucraniana",
  freedomCollectionTitle: "Colección Libertad",
  allPaintingCollectionTitle: "Colección de Todas las Pinturas",
  footerContactTitle: "Contáctanos",
  footerContactLabelEmail: "Email",
  footerContactLabelAddress: "Dirección",
  footerContactAddress: "Madrid, España",
  footerSocialText: "Sígueme en Instagram",
  footerCopyright: `© ${new Date().getFullYear()} Galería. Todos los derechos reservados.`,
  scrollToTopLabel: "Volver arriba",
};

const artworkLinkPrefix = "es/";
---

<BaseLayout title="Galería — Portafolio de Artista">
  <div class="gallery-page">
    <GalleryIndex
      galleryData={galleryData}
      translations={translations}
      artworkLinkPrefix={artworkLinkPrefix}
      showFooter
      footerVariant="split"
    />
  </div>
</BaseLayout>
