---
import BaseLayout from "../../../components/BaseLayout/BaseLayout.astro";
import ArtworkDetail from "../../../components/ArtworkDetail.astro";
import galleryData from "../../../data/gallery-es.json";
import { artwork as translations } from "../../../i18n/es";

export async function getStaticPaths() {
  const allImages = [
    ...galleryData.freedomCollection,
    ...galleryData.allPaintingCollection,
    ...galleryData.artCollection,
    galleryData.galleryContent.featured,
    ...galleryData.galleryContent.items,
  ];

  return allImages.map((image) => ({
    params: { id: image.id },
    props: { image },
  }));
}

const { image } = Astro.props;

const galleryLink = `${import.meta.env.BASE_URL}es/gallery`;
---

<BaseLayout title={`${image.alt} - Portafolio de Galería de Artista`}>
  <ArtworkDetail
    image={image}
    translations={translations}
    galleryLink={galleryLink}
  />
</BaseLayout>
