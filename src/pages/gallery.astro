---
import BaseLayout from "../components/BaseLayout/BaseLayout.astro";
import GalleryIndex from "../components/GalleryIndex.astro";
import galleryData from "../data/gallery.json";

const translations = {
  galleryTitle: "Gallery",
  galleryDescriptionLine1: "Contemporary art collection",
  galleryDescriptionLine2: "Featuring a young ukrainian artist",
  freedomCollectionTitle: "Freedom Collection",
  allPaintingCollectionTitle: "All Painting Collection",
  footerContactTitle: "Contact Us",
  footerContactLabelEmail: "Email",
  footerContactLabelAddress: "Address",
  footerContactAddress: "Madrid, Spain",
  footerSocialText: "Follow me on Instagram",
  footerCopyright: `© ${new Date().getFullYear()} Gallery. All rights reserved.`,
  scrollToTopLabel: "Back to top",
};

const artworkLinkPrefix = "";
---

<BaseLayout title="Gallery — Artist Portfolio">
  <div class="gallery-page">
    <GalleryIndex
      galleryData={galleryData}
      translations={translations}
      artworkLinkPrefix={artworkLinkPrefix}
      showPageHeader
      showFooter
      footerVariant="split"
    />
  </div>
</BaseLayout>
