---
import BaseLayout from "../../components/BaseLayout/BaseLayout.astro";
import ArtworkDetail from "../../components/ArtworkDetail.astro";
import galleryData from "../../data/gallery.json";
import { artwork as translations } from "../../i18n/en";
import { getArtworkStaticPaths } from "../../utils/artworkPaths";

export function getStaticPaths() {
  return getArtworkStaticPaths(galleryData);
}

const { image } = Astro.props;

const galleryLink = `${import.meta.env.BASE_URL}gallery`;
---

<BaseLayout title={`${image.alt} - Artist Gallery Portfolio`}>
  <ArtworkDetail
    image={image}
    translations={translations}
    galleryLink={galleryLink}
  />
</BaseLayout>
