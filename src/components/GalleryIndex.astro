---
import GalleryCardCaption from "./GalleryCardCaption.astro";
import GalleryPageFooter from "./GalleryPageFooter.astro";
import GalleryPageHero from "./GalleryPageHero.astro";
import GalleryScrollTop from "./GalleryScrollTop.astro";
import type { GalleryData } from "../types/gallery";
import type { GalleryTranslations } from "../i18n/types";

interface Props {
  galleryData: GalleryData;
  translations: GalleryTranslations;
  artworkLinkPrefix: string;
}

const { galleryData: data, translations, artworkLinkPrefix } = Astro.props;

function splitMasonryColumns<T>(items: T[]): [T[], T[]] {
  const left: T[] = [];
  const right: T[] = [];

  items.forEach((item, index) => {
    if (index % 2 === 0) {
      left.push(item);
    } else {
      right.push(item);
    }
  });

  return [left, right];
}

const [freedomLeft, freedomRight] = splitMasonryColumns(data.freedomCollection);

const [paintingLeft, paintingRight] = splitMasonryColumns([
  ...data.allPaintingCollection,
  ...data.artCollection,
]);

const galleryContentMobileItems = [
  data.galleryContent.featured,
  ...data.galleryContent.items,
];
const [galleryContentLeft, galleryContentRight] = splitMasonryColumns(
  galleryContentMobileItems,
);
---

<GalleryPageHero
  title={translations.galleryTitle}
  descriptionLine1={translations.galleryDescriptionLine1}
  descriptionLine2={translations.galleryDescriptionLine2}
/>

<article
  class="gallery-page__section gallery-page__section--reveal gallery-page__section--first"
>
  <div class="container">
    <section class="photo-gallery" id="gallery">
      <h2 class="photo-gallery__title gallery-page__target">
        {translations.freedomCollectionTitle}
      </h2>

      <div class="photo-gallery__mobile">
        {
          [freedomLeft, freedomRight].map((column) => (
            <div class="photo-gallery__col">
              {column.map((item, index) => (
                <div class="photo-gallery__item">
                  <a
                    class="photo-gallery__link"
                    href={`/${artworkLinkPrefix}artwork/${item.id}`}
                  >
                    <img
                      src={`/${item.src}`}
                      alt={item.alt}
                      class="photo-gallery__image"
                      loading={index === 0 ? "eager" : "lazy"}
                      decoding="async"
                      fetchpriority={index === 0 ? "high" : undefined}
                    />
                    <GalleryCardCaption
                      title={item.alt}
                      size={item.size}
                      price={item.price}
                    />
                  </a>
                </div>
              ))}
            </div>
          ))
        }
      </div>

      <div class="photo-gallery__grid">
        {
          data.freedomCollection.map((item, index) =>
            item.featured ? (
              <div
                class:list={[
                  "photo-gallery__item",
                  "photo-gallery__item--featured",
                  `photo-gallery__item--${index + 1}`,
                ]}
              >
                <a
                  class="photo-gallery__link"
                  href={`/${artworkLinkPrefix}artwork/${item.id}`}
                >
                  <img
                    src={`/${item.src}`}
                    alt={item.alt}
                    class="photo-gallery__image"
                    loading="lazy"
                    decoding="async"
                  />
                </a>
              </div>
            ) : null,
          )
        }
        <div class="photo-gallery__side">
          {
            data.freedomCollection.map((item, index) =>
              !item.featured ? (
                <div
                  class:list={[
                    "photo-gallery__item",
                    `photo-gallery__item--${index + 1}`,
                  ]}
                >
                  <a
                    class="photo-gallery__link"
                    href={`/${artworkLinkPrefix}artwork/${item.id}`}
                  >
                    <img
                      src={`/${item.src}`}
                      alt={item.alt}
                      class="photo-gallery__image"
                      loading="lazy"
                      decoding="async"
                    />
                  </a>
                </div>
              ) : null,
            )
          }
        </div>
      </div>
    </section>
  </div>
</article>

<article class="gallery-page__section gallery-page__section--reveal">
  <div class="container">
    <section class="photo-art">
      <h2 class="photo-art__title">
        {translations.allPaintingCollectionTitle}
      </h2>

      <div class="photo-art__mobile">
        {
          [paintingLeft, paintingRight].map((column) => (
            <div class="photo-art__col">
              {column.map((item) => (
                <div class="photo-art__item">
                  <a
                    class="photo-art__link"
                    href={`/${artworkLinkPrefix}artwork/${item.id}`}
                  >
                    <img
                      src={`/${item.src}`}
                      alt={item.alt}
                      class="photo-art__image"
                      loading="lazy"
                      decoding="async"
                    />
                    <GalleryCardCaption
                      title={item.alt}
                      size={item.size}
                      price={item.price}
                    />
                  </a>
                </div>
              ))}
            </div>
          ))
        }
      </div>

      <div class="photo-art__grid">
        {
          data.allPaintingCollection.map((item, index) => (
            <div
              class:list={[
                "photo-art__item",
                index === 0 && "photo-art__item--featured",
                `photo-art__item--${index + 1}`,
              ]}
            >
              <a
                class="photo-art__link"
                href={`/${artworkLinkPrefix}artwork/${item.id}`}
              >
                <img
                  src={`/${item.src}`}
                  alt={item.alt}
                  class="photo-art__image"
                  loading="lazy"
                  decoding="async"
                />
              </a>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</article>

<article
  class="gallery-page__section gallery-page__section--reveal gallery-page__section--art-tablet"
>
  <div class="container">
    <section class="art">
      <div class="art__grid">
        {
          data.artCollection.map((item) => (
            <div
              class={`art__item art__item--${item.id} ${item.featured ? "art__item--featured" : ""}`}
            >
              <a
                class="art__link"
                href={`/${artworkLinkPrefix}artwork/${item.id}`}
              >
                <img
                  src={`/${item.src}`}
                  alt={item.alt}
                  class="art__image"
                  loading="lazy"
                  decoding="async"
                />
              </a>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</article>

<article class="gallery-page__section gallery-page__section--reveal">
  <div class="container">
    <section class="gallery-content">
      <div class="gallery-content__mobile">
        {
          [galleryContentLeft, galleryContentRight].map((column) => (
            <div class="gallery-content__col">
              {column.map((item) => (
                <div class="gallery-content__item">
                  <a
                    class="gallery-content__link"
                    href={`/${artworkLinkPrefix}artwork/${item.id}`}
                  >
                    <img
                      src={`/${item.src}`}
                      alt={item.alt}
                      class="gallery-content__image"
                      loading="lazy"
                      decoding="async"
                    />
                    <GalleryCardCaption
                      title={item.alt}
                      size={item.size}
                      price={item.price}
                    />
                  </a>
                </div>
              ))}
            </div>
          ))
        }
      </div>

      <div class="gallery-content__featured">
        <a
          class="gallery-content__link"
          href={`/${artworkLinkPrefix}artwork/${data.galleryContent.featured.id}`}
        >
          <img
            src={`/${data.galleryContent.featured.src}`}
            alt={data.galleryContent.featured.alt}
            class="gallery-content__featured-image"
            loading="lazy"
            decoding="async"
          />
        </a>
      </div>
      <div class="gallery-content__grid">
        {
          data.galleryContent.items.map((item) => (
            <div
              class={`gallery-content__item gallery-content__item--${item.id}`}
            >
              <a
                class="gallery-content__link"
                href={`/${artworkLinkPrefix}artwork/${item.id}`}
              >
                <img
                  src={`/${item.src}`}
                  alt={item.alt}
                  class="gallery-content__image"
                  loading="lazy"
                  decoding="async"
                />
              </a>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</article>

<div class="container gallery-page__scroll-top-bar">
  <GalleryScrollTop label={translations.scrollToTopLabel} />
</div>

<GalleryPageFooter
  copyright={translations.footerCopyright}
  contactTitle={translations.footerContactTitle}
  emailLabel={translations.footerContactLabelEmail}
  address={translations.footerContactAddress}
/>
