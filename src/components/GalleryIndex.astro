---
import GalleryPageFooter, {
  type GalleryFooterVariant,
} from "./GalleryPageFooter.astro";
import GalleryPageHero from "./GalleryPageHero.astro";
import GalleryScrollTop from "./GalleryScrollTop.astro";
import type { GalleryData } from "../types/gallery";

interface Props {
  galleryData: GalleryData;
  translations: {
    galleryTitle: string;
    galleryDescriptionLine1: string;
    galleryDescriptionLine2: string;
    freedomCollectionTitle: string;
    allPaintingCollectionTitle: string;
    footerContactTitle: string;
    footerContactLabelEmail: string;
    footerContactLabelAddress: string;
    footerContactAddress: string;
    footerSocialText: string;
    footerCopyright: string;
    scrollToTopLabel: string;
  };
  artworkLinkPrefix: string;
  showFooter?: boolean;
  footerVariant?: GalleryFooterVariant;
}

const {
  galleryData: data,
  translations,
  artworkLinkPrefix,
  showFooter = false,
  footerVariant = "split",
} = Astro.props;
---

<GalleryPageHero
  title={translations.galleryTitle}
  descriptionLine1={translations.galleryDescriptionLine1}
  descriptionLine2={translations.galleryDescriptionLine2}
/>

<article class="article gallery-page__section gallery-page__section--reveal">
  <div class="container">
    <section class="photo-gallery photo-gallery--gallery-page" id="gallery">
      <div class="photo-gallery__content">
        <h2 class="photo-gallery__title">
          {translations.freedomCollectionTitle}
        </h2>
      </div>
      <div class="photo-gallery__grid photo-gallery__grid--freedom">
        {
          data.freedomCollection.map((item, index) =>
            item.featured ? (
              <div
                class:list={[
                  "photo-gallery__item",
                  "photo-gallery__item--featured",
                  `photo-gallery__item--${index + 1}`,
                ]}
              >
                <a href={`/${artworkLinkPrefix}artwork/${item.id}`}>
                  <img
                    src={`/${item.src}`}
                    alt={item.alt}
                    class="photo-gallery__image"
                    loading="lazy"
                    decoding="async"
                  />
                </a>
              </div>
            ) : null,
          )
        }
        <div class="photo-gallery__side">
          {
            data.freedomCollection.map((item, index) =>
              !item.featured ? (
                <div
                  class:list={[
                    "photo-gallery__item",
                    `photo-gallery__item--${index + 1}`,
                  ]}
                >
                  <a href={`/${artworkLinkPrefix}artwork/${item.id}`}>
                    <img
                      src={`/${item.src}`}
                      alt={item.alt}
                      class="photo-gallery__image"
                      loading="lazy"
                      decoding="async"
                    />
                  </a>
                </div>
              ) : null,
            )
          }
        </div>
      </div>
    </section>
  </div>
</article>

<article class="article gallery-page__section gallery-page__section--reveal">
  <div class="container">
    <section class="photo-art photo-art--gallery-page">
      <div class="photo-art__content">
        <h2 class="photo-art__title">
          {translations.allPaintingCollectionTitle}
        </h2>
      </div>
      <div class="photo-art__grid photo-art__grid--paintings">
        {
          data.allPaintingCollection.map((item, index) => (
            <div
              class:list={[
                "photo-art__item",
                index === 0 && "photo-art__item--featured",
                `photo-art__item--${index + 1}`,
              ]}
            >
              <a href={`/${artworkLinkPrefix}artwork/${item.id}`}>
                <img
                  src={`/${item.src}`}
                  alt={item.alt}
                  class="photo-art__image"
                  loading="lazy"
                  decoding="async"
                />
              </a>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</article>

<article class="article gallery-page__section gallery-page__section--reveal">
  <div class="container">
    <section class="art art--gallery-page">
      <div class="art__grid">
        {
          data.artCollection.map((item) => (
            <div
              class={`art__item art__item--${item.id} ${item.featured ? "art__item--featured" : ""}`}
              data-artwork-id={item.id}
            >
              <a href={`/${artworkLinkPrefix}artwork/${item.id}`}>
                <img
                  src={`/${item.src}`}
                  alt={item.alt}
                  class="art__image"
                  loading="eager"
                  decoding="async"
                />
              </a>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</article>

<article class="article gallery-page__section gallery-page__section--reveal">
  <div class="container">
    <section class="gallery-content gallery-content--gallery-page">
      <div class="gallery-content__featured">
        <a
          href={`/${artworkLinkPrefix}artwork/${data.galleryContent.featured.id}`}
        >
          <img
            src={`/${data.galleryContent.featured.src}`}
            alt={data.galleryContent.featured.alt}
            class="gallery-content__featured-image"
            loading="lazy"
            decoding="async"
            fetchpriority="high"
          />
        </a>
      </div>
      <div class="gallery-content__grid">
        {
          data.galleryContent.items.map((item) => (
            <div
              class={`gallery-content__item gallery-content__item--${item.id}`}
              data-artwork-id={item.id}
            >
              <a href={`/${artworkLinkPrefix}artwork/${item.id}`}>
                <img
                  src={`/${item.src}`}
                  alt={item.alt}
                  class="gallery-content__image"
                  loading="lazy"
                  decoding="async"
                />
              </a>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</article>

{
  showFooter && (
    <div class="container gallery-page__scroll-top-bar">
      <GalleryScrollTop label={translations.scrollToTopLabel} />
    </div>
  )
}

{
  showFooter && (
    <GalleryPageFooter
      variant={footerVariant}
      copyright={translations.footerCopyright}
      contactTitle={translations.footerContactTitle}
      emailLabel={translations.footerContactLabelEmail}
      addressLabel={translations.footerContactLabelAddress}
      address={translations.footerContactAddress}
      socialText={translations.footerSocialText}
    />
  )
}
