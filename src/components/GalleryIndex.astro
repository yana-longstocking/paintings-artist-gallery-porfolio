---
import galleryData from "../data/gallery.json";
import GalleryPageFooter, {
  type GalleryFooterVariant,
} from "./GalleryPageFooter.astro";
import GalleryScrollTop from "./GalleryScrollTop.astro";
import ContactActionButtons from "./ContactActionButtons.astro";

interface Props {
  galleryData: typeof galleryData;
  translations: {
    galleryTitle: string;
    galleryDescriptionLine1: string;
    galleryDescriptionLine2: string;
    freedomCollectionTitle: string;
    allPaintingCollectionTitle: string;
    artistBioTitle: string;
    artistBioText: string;
    footerTitle: string;
    footerFormNamePlaceholder: string;
    footerFormEmailPlaceholder: string;
    footerFormMessagePlaceholder: string;
    footerFormButtonText: string;
    footerFormSendingText: string;
    footerFormSuccessMessage: string;
    footerFormErrorMessage: string;
    footerFormErrorGeneric: string;
    footerContactTitle: string;
    footerContactLabelEmail: string;
    footerContactLabelAddress: string;
    footerContactAddress: string;
    footerSocialText: string;
    footerCopyright: string;
    scrollToTopLabel: string;
  };
  artworkLinkPrefix: string;
  showPageHeader?: boolean;
  showBioAndFooter?: boolean;
  showFooter?: boolean;
  footerVariant?: GalleryFooterVariant;
}

const {
  galleryData: data,
  translations,
  artworkLinkPrefix,
  showPageHeader = false,
  showBioAndFooter = false,
  showFooter = false,
  footerVariant = "split",
} = Astro.props;
---

{
  showPageHeader && (
    <>
      <main class="main">
        <div class="container">
          <section class="gallery gallery-page__hero" id="gallery">
            <div class="gallery__content gallery-page__hero-content">
              <h1 class="gallery__title gallery-page__hero-title">
                {translations.galleryTitle}
              </h1>
              <span class="gallery-page__hero-accent" aria-hidden="true" />
              <div class="gallery-page__hero-text">
                <p class="gallery-page__hero-text-line gallery-page__hero-text-line--first">
                  {translations.galleryDescriptionLine1}
                </p>
                <p class="gallery-page__hero-text-line gallery-page__hero-text-line--second">
                  {translations.galleryDescriptionLine2}
                </p>
              </div>
            </div>
          </section>
        </div>
      </main>

      <div class="container">
        <div class="container__line container__line--gallery-page" />
      </div>
    </>
  )
}

{
  !showPageHeader && (
    <div class="container">
      <div class="container__line home-landing__gallery-divider" />
    </div>
  )
}

<article class="article gallery-page__section gallery-page__section--reveal">
  <div class="container">
    <section class="photo-gallery" id="gallery">
      <div class="photo-gallery__content">
        <h2 class="photo-gallery__title">
          {translations.freedomCollectionTitle}
        </h2>
      </div>
      <div class="photo-gallery__grid photo-gallery__grid--freedom">
        {
          data.freedomCollection.map((item: any, index: number) =>
            item.featured ? (
              <div
                class:list={[
                  "photo-gallery__item",
                  "photo-gallery__item--featured",
                  `photo-gallery__item--${index + 1}`,
                ]}
              >
                <a href={`/${artworkLinkPrefix}artwork/${item.id}`}>
                  <img
                    src={`/${item.src}`}
                    alt={item.alt}
                    class="photo-gallery__image"
                    loading="lazy"
                    decoding="async"
                  />
                </a>
              </div>
            ) : null,
          )
        }
        <div class="photo-gallery__side">
          {
            data.freedomCollection.map((item: any, index: number) =>
              !item.featured ? (
                <div
                  class:list={[
                    "photo-gallery__item",
                    `photo-gallery__item--${index + 1}`,
                  ]}
                >
                  <a href={`/${artworkLinkPrefix}artwork/${item.id}`}>
                    <img
                      src={`/${item.src}`}
                      alt={item.alt}
                      class="photo-gallery__image"
                      loading="lazy"
                      decoding="async"
                    />
                  </a>
                </div>
              ) : null,
            )
          }
        </div>
      </div>
    </section>
  </div>
</article>

<article class="article gallery-page__section gallery-page__section--reveal">
  <div class="container">
    <section class="photo-art">
      <div class="photo-art__content">
        <h2 class="photo-art__title">
          {translations.allPaintingCollectionTitle}
        </h2>
      </div>
      <div class="photo-art__grid photo-art__grid--paintings">
        {
          data.allPaintingCollection.map((item: any, index: number) => (
            <div
              class:list={[
                "photo-art__item",
                index === 0 && "photo-art__item--featured",
                `photo-art__item--${index + 1}`,
              ]}
            >
              <a href={`/${artworkLinkPrefix}artwork/${item.id}`}>
                <img
                  src={`/${item.src}`}
                  alt={item.alt}
                  class="photo-art__image"
                  loading="lazy"
                  decoding="async"
                />
              </a>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</article>

<article class="article gallery-page__section gallery-page__section--reveal">
  <div class="container">
    <section class="art">
      <div class="art__grid">
        {
          data.artCollection.map((item: any) => (
            <div
              class={`art__item art__item--${item.id} ${item.featured ? "art__item--featured" : ""}`}
              data-artwork-id={item.id}
            >
              <a href={`/${artworkLinkPrefix}artwork/${item.id}`}>
                <img
                  src={`/${item.src}`}
                  alt={item.alt}
                  class="art__image"
                  loading="eager"
                  decoding="async"
                />
              </a>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</article>

<article class="article gallery-page__section gallery-page__section--reveal">
  <div class="container">
    <section class="gallery-content">
      <div class="gallery-content__featured">
        <a
          href={`/${artworkLinkPrefix}artwork/${data.galleryContent.featured.id}`}
        >
          <img
            src={`/${data.galleryContent.featured.src}`}
            alt={data.galleryContent.featured.alt}
            class="gallery-content__featured-image"
            loading="lazy"
            decoding="async"
            fetchpriority="high"
          />
        </a>
      </div>
      <div class="gallery-content__grid">
        {
          data.galleryContent.items.map((item: any) => (
            <div
              class={`gallery-content__item gallery-content__item--${item.id}`}
              data-artwork-id={item.id}
            >
              <a href={`/${artworkLinkPrefix}artwork/${item.id}`}>
                <img
                  src={`/${item.src}`}
                  alt={item.alt}
                  class="gallery-content__image"
                  loading="lazy"
                  decoding="async"
                />
              </a>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</article>

{
  showBioAndFooter && (
    <div class="container">
      <section class="artist-bio">
        <div class="artist-bio__content" id="artist-bio">
          <h2 class="artist-bio__title">{translations.artistBioTitle}</h2>
        </div>
        <div class="artist-bio__wrapper">
          <div class="artist-bio__image">
            <img
              src={`/${data.artistBio.src}`}
              alt={data.artistBio.alt}
              class="artist-bio__image-img"
              loading="lazy"
              decoding="async"
            />
          </div>

          <div class="artist-bio__text">{translations.artistBioText}</div>
        </div>
      </section>
    </div>
  )
}

{
  showPageHeader && showFooter && (
    <div class="container gallery-page__scroll-top-bar">
      <GalleryScrollTop label={translations.scrollToTopLabel} />
    </div>
  )
}

{
  showFooter && (
    <GalleryPageFooter
      variant={footerVariant}
      copyright={translations.footerCopyright}
      contactTitle={translations.footerContactTitle}
      emailLabel={translations.footerContactLabelEmail}
      addressLabel={translations.footerContactLabelAddress}
      address={translations.footerContactAddress}
      socialText={translations.footerSocialText}
    />
  )
}

{
  showBioAndFooter && (
    <footer class="footer footer--scroll-reveal" id="contact-us">
      <div class="container">
        <div class="footer__content">
          <div class="footer__form-section">
            <h2 class="footer__title">{translations.footerTitle}</h2>
            <form
              id="form"
              class="footer__form"
              action="https://api.web3forms.com/submit"
              method="POST"
            >
              <input
                class="footer__input"
                type="text"
                name="name"
                placeholder={translations.footerFormNamePlaceholder}
                required
              />

              <input
                type="email"
                class="footer__input"
                id="email"
                name="email"
                placeholder={translations.footerFormEmailPlaceholder}
                required
              />

              <textarea
                id="message"
                class="footer__message"
                name="message"
                placeholder={translations.footerFormMessagePlaceholder}
                required
              />

              <button type="submit" class="footer__button">
                {translations.footerFormButtonText}
              </button>
            </form>
            <div
              id="form-success"
              class="footer__success"
              style="display: none;"
            >
              <p class="footer__success-message">
                {translations.footerFormSuccessMessage}
              </p>
            </div>
          </div>

          <div class="footer__contact-section">
            <div class="footer__contact-title">
              {translations.footerContactTitle}
            </div>
            <div class="footer__contact-item">
              <p class="footer__contact-label">
                {translations.footerContactLabelAddress}
              </p>

              <a
                class="footer__contact-value"
                href="https://maps.app.goo.gl/b4ArvQcv9C2awyTb6"
                target="_blank"
              >
                {translations.footerContactAddress}
              </a>
            </div>

            <ContactActionButtons
              emailLabel={translations.footerContactLabelEmail}
              instagramLabel="Instagram"
              class="footer__contact-actions"
            />
          </div>
        </div>
        <div class="footer__copyright">
          <p class="footer__copyright-text">{translations.footerCopyright}</p>
        </div>
      </div>
    </footer>
  )
}

<script
  define:vars={{
    sendingText: translations.footerFormSendingText,
    errorMessage: translations.footerFormErrorMessage,
    errorGeneric: translations.footerFormErrorGeneric,
  }}
  is:inline
>
  function initForm() {
    const form = document.getElementById("form");
    const successMessage = document.getElementById("form-success");

    if (form && successMessage) {
      const submitBtn = form.querySelector('button[type="submit"]');

      form.addEventListener("submit", async (e) => {
        e.preventDefault();

        const formData = new FormData(form);
        formData.append("access_key", "c37ecac4-9d49-4890-ae08-b2a7ed2da3a6");

        const originalText = submitBtn.textContent;
        submitBtn.textContent = sendingText;
        submitBtn.disabled = true;

        try {
          const response = await fetch("https://api.web3forms.com/submit", {
            method: "POST",
            body: formData,
          });

          const data = await response.json();

          if (response.ok) {
            form.style.display = "none";
            successMessage.style.display = "block";
          } else {
            alert(errorMessage + ": " + data.message);
            submitBtn.textContent = originalText;
            submitBtn.disabled = false;
          }
        } catch (error) {
          alert(errorGeneric);
          submitBtn.textContent = originalText;
          submitBtn.disabled = false;
        }
      });
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initForm);
  } else {
    initForm();
  }
</script>
