---
import ImageModal from "./ImageModal/ImageModal.astro";
import ContactActionButtons from "./ContactActionButtons.astro";
import ArtworkDetailScrollReveal from "./ArtworkDetailScrollReveal.astro";
import ArtworkDetailScrollTop from "./ArtworkDetailScrollTop.astro";
import ArtworkDetailScrollDown from "./ArtworkDetailScrollDown.astro";
import type { ArtworkItem } from "../types/gallery";
import type { ArtworkTranslations } from "../i18n/types";

interface Props {
  image: ArtworkItem;
  translations: ArtworkTranslations;
  galleryLink: string;
}

const { image, translations, galleryLink } = Astro.props;
const hasAdditionalPhotos =
  image.additionalPhotos && image.additionalPhotos.length > 0;
const hasDescription = Boolean(image.description?.trim());
const isSisterhood = image.id === "sisterhood";
---

<main
  class:list={[
    "artwork-detail",
    { "artwork-detail--sisterhood": isSisterhood },
  ]}
>
  <div class="artwork-detail__container">
    <div
      class:list={[
        "artwork-detail__wrapper",
        { "artwork-detail__wrapper--with-gallery": hasAdditionalPhotos },
        {
          "artwork-detail__wrapper--no-description":
            hasAdditionalPhotos && !hasDescription,
        },
      ]}
    >
      <div class="artwork-detail__main-image">
        <img
          src={`${import.meta.env.BASE_URL}${image.src}`}
          alt={image.alt}
          class="artwork-detail__image"
          data-src-original={`${import.meta.env.BASE_URL}${image.srcOriginal || image.src}`}
          onclick="openModal(this)"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </div>

      <div class="artwork-detail__wrapper-title">
        <h1 class="artwork-detail__title">{image.alt}</h1>
        {
          image.description ? (
            <p class="artwork-detail__description">{image.description}</p>
          ) : (
            hasAdditionalPhotos && (
              <div
                class="artwork-detail__description-spacer"
                aria-hidden="true"
              />
            )
          )
        }
        {
          (image.medium || image.size || image.price) && (
            <div class="artwork-detail__purchase-info">
              {(image.medium || image.size) && (
                <div class="artwork-detail__meta">
                  {image.medium && (
                    <p class="artwork-detail__medium">{image.medium}</p>
                  )}
                  {image.size && (
                    <p class="artwork-detail__size">{image.size}</p>
                  )}
                </div>
              )}
              {image.price && (
                <p class="artwork-detail__price">{image.price}</p>
              )}
            </div>
          )
        }

        {
          hasAdditionalPhotos && (
            <div class="artwork-detail__additional-photos">
              <h2 class="artwork-detail__additional-title">
                {translations.additionalDetailsTitle}
              </h2>
              <div class="artwork-detail__gallery">
                {image.additionalPhotos!.map((photo) => (
                  <div class="artwork-detail__gallery-item">
                    <img
                      src={`${import.meta.env.BASE_URL}${photo.src}`}
                      alt={photo.alt}
                      class="artwork-detail__gallery-image"
                      data-src-original={`${import.meta.env.BASE_URL}${photo.src}`}
                      onclick="openModal(this)"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                ))}
              </div>
              <ArtworkDetailScrollDown label={translations.scrollToTopLabel} />
            </div>
          )
        }

        <ArtworkDetailScrollTop label={translations.scrollToTopLabel} />
      </div>
    </div>
  </div>

  <footer class="artwork-detail__footer">
    <div class="artwork-detail__footer-content">
      <div class="artwork-detail__footer-section">
        <h3 class="artwork-detail__footer-title">
          {translations.footerTitle}
        </h3>
        <p class="artwork-detail__footer-text">
          {translations.footerText}
        </p>
        <a href={galleryLink} class="artwork-detail__footer-link">
          <span class="artwork-detail__footer-link-text">
            {translations.footerLinkText}
          </span>
        </a>
      </div>

      <div class="artwork-detail__footer-section">
        <h3 class="artwork-detail__footer-title">
          {translations.footerContactTitle}
        </h3>
        <p class="artwork-detail__footer-text">
          {translations.footerContactText}
        </p>
        <div class="artwork-detail__footer-actions">
          <ContactActionButtons />
        </div>
      </div>
    </div>

    <div class="artwork-detail__footer-bottom">
      <p class="artwork-detail__footer-copyright">
        {translations.footerCopyright}
      </p>
    </div>
  </footer>
</main>

<ImageModal imageData={image} />
<ArtworkDetailScrollReveal />
