---
import HeroMosaic from "./HeroMosaic.astro";
import ContactActionButtons from "./ContactActionButtons.astro";

interface GalleryData {
  freedomCollection: { id: string; src: string; alt: string }[];
  allPaintingCollection: { id: string; src: string; alt: string }[];
  artCollection: { id: string; src: string; alt: string }[];
  galleryContent: {
    featured: { id: string; src: string; alt: string };
    items: { id: string; src: string; alt: string }[];
  };
  artistBio: { src: string; alt: string };
}

interface Props {
  galleryData: GalleryData;
  artworkLinkPrefix: string;
  galleryHref: string;
  translations: {
    viewAllWorksLabel: string;
    mobileHeroTagline: string;
    artistBioTitle: string;
    artistBioText: string;
    footerTitle: string;
    footerFormNamePlaceholder: string;
    footerFormEmailPlaceholder: string;
    footerFormMessagePlaceholder: string;
    footerFormButtonText: string;
    footerFormSendingText: string;
    footerFormSuccessMessage: string;
    footerFormErrorMessage: string;
    footerFormErrorGeneric: string;
    footerContactTitle: string;
    footerContactLabelEmail: string;
    footerContactLabelAddress: string;
    footerContactAddress: string;
    footerSocialText: string;
    footerCopyright: string;
  };
}

const {
  galleryData: data,
  artworkLinkPrefix,
  galleryHref,
  translations,
} = Astro.props;

type MosaicItem = { id: string; src: string; alt: string };

const featuredPiece: MosaicItem = {
  id: data.galleryContent.featured.id,
  src: data.galleryContent.featured.src,
  alt: data.galleryContent.featured.alt,
};

const mosaicBuckets: MosaicItem[][] = [
  data.freedomCollection as MosaicItem[],
  data.allPaintingCollection as MosaicItem[],
  data.artCollection as MosaicItem[],
  data.galleryContent.items as MosaicItem[],
];

const seenIds = new Set<string>([featuredPiece.id]);
const sidePicks: MosaicItem[] = [];
const cursor = [0, 0, 0, 0];

const takeNextFrom = (bucketIndex: number): MosaicItem | null => {
  const list = mosaicBuckets[bucketIndex];
  while (cursor[bucketIndex] < list.length) {
    const p = list[cursor[bucketIndex]++];
    if (seenIds.has(p.id)) continue;
    seenIds.add(p.id);
    return p;
  }
  return null;
};

while (sidePicks.length < 6) {
  let addedThisRound = false;
  for (let b = 0; b < mosaicBuckets.length; b++) {
    if (sidePicks.length >= 6) break;
    const next = takeNextFrom(b);
    if (next) {
      sidePicks.push(next);
      addedThisRound = true;
    }
  }
  if (!addedThisRound) break;
}

if (sidePicks.length < 6) {
  const fallback = [
    ...(data.freedomCollection as MosaicItem[]),
    ...(data.allPaintingCollection as MosaicItem[]),
    ...(data.artCollection as MosaicItem[]),
    ...(data.galleryContent.items as MosaicItem[]),
  ];
  for (const p of fallback) {
    if (sidePicks.length >= 6) break;
    if (seenIds.has(p.id)) continue;
    seenIds.add(p.id);
    sidePicks.push(p);
  }
}

const isFreedomSeries = (p: MosaicItem) => p.id.startsWith("series-freedom-");
const freedomIdx = sidePicks
  .map((p, i) => (isFreedomSeries(p) ? i : -1))
  .filter((i) => i >= 0);
if (freedomIdx.length >= 2) {
  const usedIds = new Set<string>([
    featuredPiece.id,
    ...sidePicks.map((p) => p.id),
  ]);
  const pool: MosaicItem[] = [
    ...(data.allPaintingCollection as MosaicItem[]),
    ...(data.artCollection as MosaicItem[]),
    ...(data.galleryContent.items as MosaicItem[]),
  ];
  const replacement = pool.find(
    (p) => !usedIds.has(p.id) && !isFreedomSeries(p),
  );
  if (replacement) {
    sidePicks[freedomIdx[1]] = replacement;
  }
}

const findMosaicItem = (id: string): MosaicItem | undefined => {
  const all: MosaicItem[] = [
    ...(data.freedomCollection as MosaicItem[]),
    ...(data.allPaintingCollection as MosaicItem[]),
    ...(data.artCollection as MosaicItem[]),
    data.galleryContent.featured as MosaicItem,
    ...(data.galleryContent.items as MosaicItem[]),
  ];
  return all.find((item) => item.id === id);
};

const mapDancerForHero = (p: MosaicItem): MosaicItem => {
  if (p.id !== "dancer") return p;
  const replacement = findMosaicItem("pretty-girls-do-cry-2");
  return replacement ?? p;
};

const heroMosaicPieces = [
  sidePicks[0],
  sidePicks[1],
  sidePicks[2],
  featuredPiece,
  sidePicks[3],
  sidePicks[4],
  sidePicks[5],
]
  .filter((p): p is MosaicItem => Boolean(p))
  .map(mapDancerForHero)
  .map((p) => ({ id: p.id, src: p.src, alt: p.alt }));
---

<main class="main main--under-nav-hero">
  <div class="hero-mosaic-viewport">
    <HeroMosaic
      pieces={heroMosaicPieces}
      artworkLinkPrefix={artworkLinkPrefix}
      galleryHref={galleryHref}
      galleryLabel={translations.viewAllWorksLabel}
      mobileHeroTagline={translations.mobileHeroTagline}
    />
  </div>
</main>

<div class="container">
  <section class="artist-bio artist-bio--reveal">
    <div class="artist-bio__content" id="artist-bio">
      <h2 class="artist-bio__title">{translations.artistBioTitle}</h2>
    </div>
    <div class="artist-bio__wrapper">
      <div class="artist-bio__image">
        <img
          src={`/${data.artistBio.src}`}
          alt={data.artistBio.alt}
          class="artist-bio__image-img"
          loading="lazy"
          decoding="async"
        />
      </div>

      <div class="artist-bio__text">
        {translations.artistBioText}
      </div>
    </div>
  </section>
</div>

<footer class="footer footer--scroll-reveal" id="contact-us">
  <div class="container">
    <div class="footer__content">
      <div class="footer__form-section">
        <h2 class="footer__title">{translations.footerTitle}</h2>
        <form
          id="form"
          class="footer__form"
          action="https://api.web3forms.com/submit"
          method="POST"
        >
          <input
            class="footer__input"
            type="text"
            name="name"
            placeholder={translations.footerFormNamePlaceholder}
            required
          />

          <input
            type="email"
            class="footer__input"
            id="email"
            name="email"
            placeholder={translations.footerFormEmailPlaceholder}
            required
          />

          <textarea
            id="message"
            class="footer__message"
            name="message"
            placeholder={translations.footerFormMessagePlaceholder}
            required></textarea>

          <button type="submit" class="footer__button"
            >{translations.footerFormButtonText}</button
          >
        </form>
        <div id="form-success" class="footer__success" style="display: none;">
          <p class="footer__success-message">
            {translations.footerFormSuccessMessage}
          </p>
        </div>
      </div>

      <div class="footer__contact-section">
        <div class="footer__contact-title">
          {translations.footerContactTitle}
        </div>
        <div class="footer__contact-item">
          <p class="footer__contact-label">
            {translations.footerContactLabelAddress}
          </p>

          <a
            class="footer__contact-value"
            href="https://maps.app.goo.gl/b4ArvQcv9C2awyTb6"
            target="_blank"
          >
            {translations.footerContactAddress}
          </a>
        </div>

        <ContactActionButtons
          emailLabel={translations.footerContactLabelEmail}
          instagramLabel="Instagram"
          class="footer__contact-actions"
        />
      </div>
    </div>
    <div class="footer__copyright">
      <p class="footer__copyright-text">
        {translations.footerCopyright}
      </p>
    </div>
  </div>
</footer>

<script
  define:vars={{
    sendingText: translations.footerFormSendingText,
    errorMessage: translations.footerFormErrorMessage,
    errorGeneric: translations.footerFormErrorGeneric,
  }}
  is:inline
>
  function initForm() {
    const form = document.getElementById("form");
    const successMessage = document.getElementById("form-success");

    if (form && successMessage) {
      const submitBtn = form.querySelector('button[type="submit"]');

      form.addEventListener("submit", async (e) => {
        e.preventDefault();

        const formData = new FormData(form);
        formData.append("access_key", "c37ecac4-9d49-4890-ae08-b2a7ed2da3a6");

        const originalText = submitBtn.textContent;
        submitBtn.textContent = sendingText;
        submitBtn.disabled = true;

        try {
          const response = await fetch("https://api.web3forms.com/submit", {
            method: "POST",
            body: formData,
          });

          const data = await response.json();

          if (response.ok) {
            form.style.display = "none";
            successMessage.style.display = "block";
          } else {
            alert(errorMessage + ": " + data.message);
            submitBtn.textContent = originalText;
            submitBtn.disabled = false;
          }
        } catch (error) {
          alert(errorGeneric);
          submitBtn.textContent = originalText;
          submitBtn.disabled = false;
        }
      });
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initForm);
  } else {
    initForm();
  }

  function initArtistBioReveal() {
    const bio = document.querySelector(".artist-bio--reveal");
    if (!bio) return;

    const wrapper = bio.querySelector(".artist-bio__wrapper");
    if (!wrapper) return;

    const revealTitle = () => bio.classList.add("artist-bio--visible");
    const revealContent = () =>
      bio.classList.add("artist-bio--content-visible");
    const revealAll = () => {
      revealTitle();
      revealContent();
    };

    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      revealAll();
      return;
    }

    if (window.location.hash === "#artist-bio") {
      revealAll();
      return;
    }

    const minScroll = 40;
    let titleDone = false;
    let contentDone = false;

    const cleanup = () => {
      window.removeEventListener("scroll", onScroll);
      titleObserver.disconnect();
      contentObserver.disconnect();
    };

    const tryRevealTitle = () => {
      if (titleDone) return;
      if (window.scrollY < minScroll) return;

      const rect = bio.getBoundingClientRect();
      if (rect.top > window.innerHeight * 0.88) return;

      titleDone = true;
      revealTitle();
      if (contentDone) cleanup();
    };

    const tryRevealContent = () => {
      if (contentDone) return;
      if (window.scrollY < minScroll) return;

      const rect = wrapper.getBoundingClientRect();
      if (rect.top > window.innerHeight * 0.58) return;

      contentDone = true;
      revealContent();
      if (titleDone) cleanup();
    };

    const onScroll = () => {
      tryRevealTitle();
      tryRevealContent();
    };

    const titleObserver = new IntersectionObserver(() => tryRevealTitle(), {
      threshold: 0,
    });
    const contentObserver = new IntersectionObserver(() => tryRevealContent(), {
      threshold: 0,
    });

    titleObserver.observe(bio);
    contentObserver.observe(wrapper);
    window.addEventListener("scroll", onScroll, { passive: true });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initArtistBioReveal);
  } else {
    initArtistBioReveal();
  }
</script>
