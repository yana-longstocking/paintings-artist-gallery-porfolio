---
interface Props {
  title: string;
  descriptionLine1: string;
  descriptionLine2: string;
}

const { title, descriptionLine1, descriptionLine2 } = Astro.props;
---

<main>
  <div class="container">
    <section class="gallery-page__hero" id="gallery">
      <div class="gallery-page__hero-content">
        <h1 class="gallery-page__hero-title">{title}</h1>
        <span class="gallery-page__hero-accent" aria-hidden="true"></span>
        <div class="gallery-page__hero-text">
          <p
            class="gallery-page__hero-text-line gallery-page__hero-text-line--first"
          >
            {descriptionLine1}
          </p>
          <p
            class="gallery-page__hero-text-line gallery-page__hero-text-line--second"
          >
            {descriptionLine2}
          </p>
        </div>
      </div>
    </section>
  </div>
</main>

<div class="container">
  <div class="gallery-page__divider"></div>
</div>
