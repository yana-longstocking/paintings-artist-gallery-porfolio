---
export interface HeroMosaicPiece {
  id: string;
  src: string;
  alt: string;
}

interface Props {
  pieces: HeroMosaicPiece[];
  artworkLinkPrefix: string;
  galleryHref?: string;
  galleryLabel?: string;
  mobileHeroTagline?: string;
}

const {
  pieces,
  artworkLinkPrefix,
  galleryHref,
  galleryLabel,
  mobileHeroTagline,
} = Astro.props;

const slotClasses = [
  "hero-mosaic__cell--a",
  "hero-mosaic__cell--b",
  "hero-mosaic__cell--c",
  "hero-mosaic__cell--d",
  "hero-mosaic__cell--e",
  "hero-mosaic__cell--f",
  "hero-mosaic__cell--g",
] as const;

const cells = pieces.slice(0, slotClasses.length);
const featuredIndex = Math.min(3, pieces.length - 1);
const featuredPiece = pieces[featuredIndex] ?? pieces[0];
---

<section class="hero-mosaic hero-mosaic--under-nav" aria-label="Welcome">
  <div class="hero-mosaic__inner">
    <div class="hero-mosaic__mobile-hero">
      <div class="hero-mosaic__mobile-feature">
        {
          featuredPiece && (
            <a
              href={`/${artworkLinkPrefix}artwork/${featuredPiece.id}`}
              class="hero-mosaic__mobile-photo"
              aria-label={featuredPiece.alt}
            >
              <img
                src={`/${featuredPiece.src}`}
                alt={featuredPiece.alt}
                class="hero-mosaic__mobile-photo-img"
                width="800"
                height="1000"
                loading="eager"
                decoding="async"
                fetchpriority="high"
              />
            </a>
          )
        }
        <div class="hero-mosaic__mobile-copy">
          {
            mobileHeroTagline && (
              <p class="hero-mosaic__mobile-tagline">{mobileHeroTagline}</p>
            )
          }
          {
            galleryHref && galleryLabel && (
              <a href={galleryHref} class="hero-mosaic__mobile-cta">
                {galleryLabel}
              </a>
            )
          }
        </div>
      </div>
    </div>

    <div class="hero-mosaic__grid">
      {
        cells.map((piece, i) => (
          <a
            href={`/${artworkLinkPrefix}artwork/${piece.id}`}
            class:list={["hero-mosaic__cell", slotClasses[i]]}
          >
            <img
              src={`/${piece.src}`}
              alt={piece.alt}
              class="hero-mosaic__img"
              width="800"
              height="1000"
              loading="eager"
              decoding="async"
              fetchpriority={i === 3 ? "high" : undefined}
            />
          </a>
        ))
      }
      {
        galleryHref && galleryLabel && (
          <div class="hero-mosaic__cta">
            <a href={galleryHref} class="hero-mosaic__cta-link">
              {galleryLabel}
            </a>
          </div>
        )
      }
    </div>
  </div>
</section>

<script src="./HeroMosaic.client.ts"></script>
