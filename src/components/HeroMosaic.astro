---
export interface HeroMosaicPiece {
  id: string;
  src: string;
  alt: string;
}

interface Props {
  pieces: HeroMosaicPiece[];
  artworkLinkPrefix: string;
  galleryHref?: string;
  galleryLabel?: string;
  mobileHeroTagline?: string;
}

const {
  pieces,
  artworkLinkPrefix,
  galleryHref,
  galleryLabel,
  mobileHeroTagline,
} = Astro.props;

const slotClasses = [
  "hero-mosaic__cell--a",
  "hero-mosaic__cell--b",
  "hero-mosaic__cell--c",
  "hero-mosaic__cell--d",
  "hero-mosaic__cell--e",
  "hero-mosaic__cell--f",
  "hero-mosaic__cell--g",
] as const;

const cells = pieces.slice(0, slotClasses.length);
const featuredIndex = Math.min(3, pieces.length - 1);
const featuredPiece = pieces[featuredIndex] ?? pieces[0];
---

<section class="hero-mosaic hero-mosaic--under-nav" aria-label="Welcome">
  <div class="hero-mosaic__inner">
    <div class="hero-mosaic__mobile-hero">
      <div class="hero-mosaic__mobile-feature">
        {
          featuredPiece && (
            <a
              href={`/${artworkLinkPrefix}artwork/${featuredPiece.id}`}
              class="hero-mosaic__mobile-photo"
              aria-label={featuredPiece.alt}
            >
              <img
                src={`/${featuredPiece.src}`}
                alt={featuredPiece.alt}
                class="hero-mosaic__mobile-photo-img"
                width="800"
                height="1000"
                loading="eager"
                decoding="async"
                fetchpriority="high"
              />
            </a>
          )
        }
        <div class="hero-mosaic__mobile-copy">
          {
            mobileHeroTagline && (
              <p class="hero-mosaic__mobile-tagline">{mobileHeroTagline}</p>
            )
          }
          {
            galleryHref && galleryLabel && (
              <a href={galleryHref} class="hero-mosaic__mobile-cta">
                {galleryLabel}
              </a>
            )
          }
        </div>
      </div>
    </div>

    <div class="hero-mosaic__grid">
      {
        cells.map((piece, i) => (
          <a
            href={`/${artworkLinkPrefix}artwork/${piece.id}`}
            class:list={["hero-mosaic__cell", slotClasses[i]]}
          >
            <img
              src={`/${piece.src}`}
              alt={piece.alt}
              class="hero-mosaic__img"
              width="800"
              height="1000"
              loading="eager"
              decoding="async"
              fetchpriority={i === 3 ? "high" : undefined}
            />
          </a>
        ))
      }
      {
        galleryHref && galleryLabel && (
          <div class="hero-mosaic__cta">
            <a href={galleryHref} class="hero-mosaic__cta-link">
              {galleryLabel}
            </a>
          </div>
        )
      }
    </div>
  </div>
</section>

<script is:inline>
  function showMosaicCtaWhenReady() {
    const mosaic = document.querySelector(".hero-mosaic--under-nav");
    if (!mosaic) return;

    if (window.matchMedia("(max-width: 743px)").matches) {
      return;
    }

    const images = Array.from(mosaic.querySelectorAll(".hero-mosaic__img"));
    const ctaWrap = mosaic.querySelector(".hero-mosaic__cta");
    const cta = mosaic.querySelector(".hero-mosaic__cta-link");
    if (!cta || !ctaWrap) return;

    let revealed = false;
    const reveal = () => {
      if (revealed) return;
      revealed = true;
      ctaWrap.classList.add("hero-mosaic__cta--ready");
      cta.classList.add("hero-mosaic__cta-link--ready");
    };

    const fallback = window.setTimeout(reveal, 10000);

    const revealAndClear = () => {
      window.clearTimeout(fallback);
      reveal();
    };

    const waitForImage = (img) =>
      new Promise((resolve) => {
        const finish = async () => {
          if (typeof img.decode === "function") {
            try {
              await img.decode();
            } catch {
              // Show CTA even if decode fails.
            }
          }
          resolve();
        };

        if (img.complete) {
          finish();
          return;
        }

        img.addEventListener("load", finish, { once: true });
        img.addEventListener("error", finish, { once: true });
      });

    const waitForLastCellAnimation = () =>
      new Promise((resolve) => {
        const lastCell = mosaic.querySelector(".hero-mosaic__cell--g");
        let settled = false;

        const done = () => {
          if (settled) return;
          settled = true;
          resolve();
        };

        if (!lastCell) {
          done();
          return;
        }

        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
          window.setTimeout(resolve, 80);
          return;
        }

        const fallback = window.setTimeout(done, 2000);
        const enterAnim = lastCell
          .getAnimations()
          .find((anim) => anim.animationName === "hero-mosaic-cell-enter");

        if (enterAnim) {
          const timing = enterAnim.effect?.getComputedTiming?.() ?? {};
          const delay = Number(timing.delay) || 0;
          const duration = Number(timing.duration) || 1900;
          const revealAt = delay + duration * 0.5;

          if (enterAnim.playState === "finished") {
            window.clearTimeout(fallback);
            done();
            return;
          }

          const current = Number(enterAnim.currentTime) || 0;
          const waitMs = Math.max(0, revealAt - current);

          window.setTimeout(() => {
            window.clearTimeout(fallback);
            done();
          }, waitMs);
          return;
        }

        const onEnd = (event) => {
          if (event.target !== lastCell) return;
          lastCell.removeEventListener("animationend", onEnd);
          window.clearTimeout(fallback);
          done();
        };

        lastCell.addEventListener("animationend", onEnd);
      });

    const waitForMosaic = async () => {
      if (!images.length) {
        revealAndClear();
        return;
      }

      await Promise.all([
        Promise.all(images.map(waitForImage)),
        waitForLastCellAnimation(),
      ]);
      revealAndClear();
    };

    waitForMosaic();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", showMosaicCtaWhenReady);
  } else {
    showMosaicCtaWhenReady();
  }
</script>
